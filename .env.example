# Supabase — publishable keys (safe in the client bundle because RLS protects data)
# Copy to .env.local and fill in your project values from:
#   Supabase dashboard → Settings → API
#
# Leave blank (or omit) to run the app fully locally without auth/sync.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
